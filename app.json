{
  "expo": {
    "name": "aitv-lms",
    "slug": "aitv-lms",
    "scheme": "aitv-lms",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./src/assets/images/app-icons/icon_1.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hoe.aitv-lms",
      "infoPlist": {
        "UISupportedInterfaceOrientations": [
          "UIInterfaceOrientationPortrait",
          "UIInterfaceOrientationLandscapeLeft",
          "UIInterfaceOrientationLandscapeRight"
        ],
        "UISupportedInterfaceOrientations~ipad": [
          "UIInterfaceOrientationPortrait",
          "UIInterfaceOrientationPortraitUpsideDown",
          "UIInterfaceOrientationLandscapeLeft",
          "UIInterfaceOrientationLandscapeRight"
        ]
      },
      "appleTeamId": "R5FK69QU84"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/app-icons/icon_1.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.hoe.aitvlms"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      "expo-font",
      "expo-video",
      [
        "expo-quick-actions/icon/plugin",
        {
          "icon1": {
            "image": "./src/assets/images/app-icons/icon_1.png"
          },
          "icon2": {
            "image": "./src/assets/images/app-icons/icon_2.png"
          },
          "icon3": {
            "image": "./src/assets/images/app-icons/icon_3.png"
          },
          "icon4": {
            "image": "./src/assets/images/app-icons/icon_4.png"
          },
          "icon5": {
            "image": "./src/assets/images/app-icons/icon_5.png"
          }
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "aitv-lms",
          "organization": "aitv-lms"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2c910706-e10c-4421-869b-cf5d19fcd9f8"
      }
    }
  }
}
